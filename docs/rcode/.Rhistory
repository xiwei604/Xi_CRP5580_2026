# Store in dataframe
pred_all <- rbind(pred_all, data.frame(pred = pred, actual = test_idx$nonfly, fold = i))
}
ggplot(pred_all, aes(x = actual, y = pred)) +
geom_point(alpha = 0.4, color = "steelblue") +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "red") +
labs(title = "Predicted vs Actual (10-fold CV)",
x = "Actual Crash Count",
y = "Predicted Crash Count") +
theme_minimal()
pred_all$residual <- pred_all$actual - pred_all$pred
ggplot(pred_all, aes(x = pred, y = residual)) +
geom_point(alpha = 0.4, color = "darkgreen") +
geom_hline(yintercept = 0, linetype = "dashed") +
labs(title = "Residual Plot", x = "Predicted", y = "Residual (Actual - Predicted)") +
theme_minimal()
library(sf)
library(dplyr)
library(spdep)
library(spatialreg)
library(MASS)
# 读取 shapefile（包含几何和变量）
tract_sf <- st_read("C:/Users/Nancy/Desktop/avc/geoda1.shp")
df <- read.csv("C:/Users/Nancy/Desktop/final.csv")
df <- df %>%
filter(nonfly > 0)
# 确保 GEOID 都是字符型
tract_sf$GEOID <- as.character(tract_sf$GEOID)
df$GEOID <- as.character(df$GEOID)
# 合并成一个 sf 对象
sf_data <- left_join(tract_sf, df, by = "GEOID")
# 创建比例变量（如果没创建过）
sf_data <- sf_data %>%
mutate(
Forest_prop = Forest / AreaAcrs.x,
Wetland_prop = Wetland / AreaAcrs.x,
ShrublandGrassland_prop = ShrublandGrassland / AreaAcrs.x,
Cropland_prop = Cropland / AreaAcrs.x,
Water_prop = Water / AreaAcrs.x,
UbranBuiltup_prop = UbranBuiltup / AreaAcrs.x,
log_POP = log(POP.x + 1)
)
# 建立空间权重矩阵
nb <- poly2nb(sf_data)
lw <- nb2listw(nb, style = "W")
formula <- nonfly_1 ~
Forest_prop * log_POP +
ShrublandGrassland_prop * log_POP +
Water_prop +
UbranBuiltup_prop * log_POP +
WeightWLAreaPercentage * log_POP +
avg_AADT.x +
avg_SPEED_LIMIT +
Interstate + MinorArterial +
MajorCollector + MinorCollector + Local +
MEAN_SURFACE_WIDTH +
MEAN_IncidentClearanceTime_min +
MEAN_RdClearanceTime_minute
# -----------------------------
# ⚙️ 空间滞后模型
# -----------------------------
lag_model <- lagsarlm(formula, data = sf_data, listw = lw)
summary(lag_model)
# -----------------------------
# ⚙️ 空间误差模型（可选）
# -----------------------------
error_model <- errorsarlm(formula, data = sf_data, listw = lw)
summary(error_model)
# -----------------------------
# 📊 比较 AIC
# -----------------------------
AIC(lag_model, error_model)
model_data <- sf_data %>%
filter(nonfly.y > 0) %>%
st_drop_geometry()
# Check if the size matches model inputs
nrow(model_data)
# Step 2: Add predicted and residuals to model_data
model_data$predicted_error <- fitted(error_model)
model_data$residual_error <- model_data$nonfly_1 - model_data$predicted_error
# Step 3: Join back to full sf_data for mapping
sf_data <- sf_data %>%
left_join(model_data %>% select(GEOID, predicted_error, residual_error), by = "GEOID")
summary(sf_data$predicted_error)
summary(sf_data$residual_error)
library(ggplot2)
ggplot(sf_data) +
geom_sf(aes(fill = predicted_error)) +
scale_fill_viridis_c(na.value = "grey90") +
labs(title = "Predicted AVCs (Spatial Error Model)", fill = "Predicted") +
theme_minimal()
ggplot(sf_data) +
geom_sf(aes(fill = residual_error)) +
scale_fill_gradient2(midpoint = 0, low = "blue", mid = "white", high = "red", na.value = "grey90") +
labs(title = "Residuals: Actual - Predicted", fill = "Residual") +
theme_minimal()
